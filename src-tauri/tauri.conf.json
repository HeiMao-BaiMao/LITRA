{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LITRA",
  "version": "1.0.0",
  "identifier": "org.hmbm.litra",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LITRA",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "license": "BSD-2-Clause",
    "licenseFile": "../LICENSE.rtf",
    "resources": {
      "../legal/THIRD_PARTY_LICENSES.json": "legal/THIRD_PARTY_LICENSES.json",
      "../legal/THIRD_PARTY_LICENSES.md": "legal/THIRD_PARTY_LICENSES.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
